---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.topic === 'biomarkers');
  return articles.map(article => {
    const parts = article.id.replace(/\.md$/, '').split('/');
    const slug = parts[parts.length - 1];
    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content } = await render(article);
const topic = article.data.topic;
const label = topic.charAt(0).toUpperCase() + topic.slice(1);
---

<Base
  title={article.data.title}
  description={article.data.description}
  type="article"
>
  <Header activeTopic={topic} />
  <main class="container">
    <article>
      <div class="article-header">
        <a
          href={`/${topic}/`}
          class={`article-header__topic article-item__topic--${topic}`}
        >
          {label}
        </a>
        <h1 class="article-header__title">{article.data.title}</h1>
        <p class="article-header__desc">{article.data.description}</p>
        <span class="article-header__meta">
          {article.data.readTime} &middot; Updated {article.data.updated}
        </span>
      </div>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Base>
